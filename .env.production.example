# Copie para .env.production na raiz do projeto antes do deploy
# cp .env.production.example .env.production

POSTGRES_DB=barbershop
POSTGRES_USER=barbershop
POSTGRES_PASSWORD=change-me-strong-password
HTTP_PORT=80

APP_NAME="BarberShop API"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://barber.wynext.online
APP_TIMEZONE=America/Sao_Paulo

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=barbershop
DB_USERNAME=barbershop
DB_PASSWORD=change-me-strong-password

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=redis

SANCTUM_STATEFUL_DOMAINS=barber.wynext.online,app.wynext.online
SESSION_DOMAIN=.wynext.online
